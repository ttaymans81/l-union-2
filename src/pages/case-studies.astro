---
import MainLayout from "../layouts/MainLayout.astro";
import CaseStudies from "../components/CaseStudies.astro";
---

<MainLayout>
  <section class="mx-auto max-w-7xl px-8 py-24">
    <p class="uppercase text-sm tracking-[0.25em] text-neutral-500">
      Case Studies
    </p>

    <h1 class="mt-6 max-w-4xl text-6xl font-black leading-[0.95]">
      Selected work and creative projects.
    </h1>

    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-neutral-600">
      Discover how L'Union helps organizations create meaningful impact through strategy, creativity and digital experiences.
    </p>
  </section>

  <CaseStudies />
</MainLayout>