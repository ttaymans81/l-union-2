---
import MainLayout from "../layouts/MainLayout.astro";
import { sanityClient } from "../lib/sanity";

const projects = await sanityClient.fetch(`
  *[_type == "caseStudy"]{
    title,
    "slug": slug.current,
    category,
    description,
    "imageUrl": image.asset->url
  }
`);
---

<MainLayout>
  <section class="mx-auto max-w-7xl px-8 py-24">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
      Case Studies
    </p>

    <div class="mt-6 grid gap-10 lg:grid-cols-[0.55fr_0.45fr]">
      <h1 class="max-w-4xl text-6xl font-black leading-[0.95] tracking-[-0.05em]">
        Selected work and creative projects.
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-neutral-600 lg:pt-4">
        Discover how L'Union helps organizations create meaningful impact through strategy,
        creativity and digital experiences.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-8 pb-28">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <a href={`/case-studies/${project.slug}`} class="group block">
          <div class="aspect-[1.05] overflow-hidden bg-neutral-200">
            {project.imageUrl && (
              <img
                src={project.imageUrl}
                alt={project.title}
                class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
              />
            )}
          </div>

          <p class="mt-5 text-xs font-semibold uppercase tracking-[0.22em] text-neutral-400">
            {project.category}
          </p>

          <h2 class="mt-3 text-2xl font-black tracking-[-0.03em]">
            {project.title}
          </h2>

          <p class="mt-3 leading-relaxed text-neutral-600">
            {project.description}
          </p>
        </a>
      ))}
    </div>
  </section>
</MainLayout>