---
import MainLayout from "../layouts/MainLayout.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
---

<MainLayout>

<section class="mx-auto max-w-7xl px-8 pt-6 pb-24 md:pt-8">

  <p class="uppercase text-sm tracking-[0.25em] text-neutral-500">
    Services
  </p>

  <h1 class="mt-6 max-w-3xl text-5xl font-black leading-[0.95] md:text-6xl">
    Strategic, creative and digital services for organizations that want impact.
  </h1>

  <p class="mt-8 max-w-2xl text-lg leading-relaxed text-neutral-600">
    From strategy to campaigns, digital experiences and production,
    L'Union helps brands and institutions connect with the people who matter.
  </p>

</section>

<ServicesGrid showLink={false} />

<section class="mx-auto max-w-7xl px-8 py-24">

  <div class="grid gap-16 lg:grid-cols-2">

    <div>

      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
        Our methodology
      </p>

      <h2 class="mt-5 text-5xl font-black tracking-[-0.04em]">
        Strategy first. Execution second.
      </h2>

    </div>

    <div>

      <p class="leading-relaxed text-neutral-600">
        Every successful communication project starts with a clear understanding
        of the challenge. We help organizations define priorities, identify
        opportunities and create actions that generate measurable impact.
      </p>

      <p class="mt-6 leading-relaxed text-neutral-600">
        From strategic planning to creative execution, we ensure that every
        initiative serves a clear objective and contributes to long-term value.
      </p>

    </div>

  </div>

</section>

<section class="bg-[#f1f0ec]">
  <div class="mx-auto max-w-7xl px-8 py-24">

    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
      Why L'Union
    </p>

    <div class="mt-10 grid gap-10 md:grid-cols-3">

      <div>
        <h3 class="text-2xl font-black">Strategic Thinking</h3>

        <p class="mt-4 leading-relaxed text-neutral-600">
          We start with the challenge before proposing solutions.
        </p>
      </div>

      <div>
        <h3 class="text-2xl font-black">Creative Excellence</h3>

        <p class="mt-4 leading-relaxed text-neutral-600">
          Ideas are only valuable when they create engagement and impact.
        </p>
      </div>

      <div>
        <h3 class="text-2xl font-black">Execution & Results</h3>

        <p class="mt-4 leading-relaxed text-neutral-600">
          We transform strategy into concrete actions and measurable outcomes.
        </p>
      </div>

    </div>

  </div>
</section>

</MainLayout>