---
import { sanityClient } from "../lib/sanity";

const services = await sanityClient.fetch(`
  *[_type == "service"] | order(order asc){
    title,
    description,
    icon
  }
`);

const svg = {
  target: `
    <circle cx="12" cy="12" r="8"/>
    <circle cx="12" cy="12" r="3"/>
    <path d="M12 4v3M12 17v3M4 12h3M17 12h3"/>
  `,

  network: `
    <circle cx="12" cy="5" r="2"/>
    <circle cx="5" cy="18" r="2"/>
    <circle cx="19" cy="18" r="2"/>
    <path d="M12 7v5"/>
    <path d="M12 12L5 16"/>
    <path d="M12 12l7 4"/>
  `,

  megaphone: `
    <path d="M4 13h3l8 4V7l-8 4H4v2z"/>
    <path d="M7 13l1 5h3"/>
  `,

  users: `
    <circle cx="9" cy="8" r="3"/>
    <circle cx="17" cy="9" r="2.5"/>
    <path d="M3 19c1-4 11-4 12 0"/>
    <path d="M14 18c1-2 6-2 7 0"/>
  `,

  bubble: `
    <path d="M4 6h16v10H8l-4 4V6z"/>
  `,

  play: `
    <circle cx="12" cy="12" r="9"/>
    <path d="M10 8l6 4-6 4V8z"/>
  `,

  screen: `
    <rect x="4" y="5" width="16" height="11" rx="1"/>
    <path d="M9 20h6M12 16v4"/>
  `,

  hash: `
    <path d="M9 4L7 20M17 4l-2 16M4 9h16M3 15h16"/>
  `,

  calendar: `
    <rect x="4" y="6" width="16" height="14" rx="1"/>
    <path d="M8 4v4M16 4v4M4 10h16"/>
  `,

  document: `
    <path d="M6 3h9l3 3v15H6V3z"/>
    <path d="M15 3v4h4M9 12h6M9 16h6"/>
  `,
};
---

<section class="bg-[#f1f0ec]">
  <div class="mx-auto grid max-w-7xl gap-12 px-8 py-20 lg:grid-cols-[0.28fr_0.72fr]">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-neutral-500">
        What we do
      </p>

      <h2 class="mt-5 text-4xl font-black leading-tight tracking-[-0.04em]">
        Services that create impact
      </h2>

      <p class="mt-5 leading-relaxed text-neutral-600">
        We combine strategy, creativity and technology to deliver meaningful results.
      </p>

      <a href="/services" class="mt-6 inline-block font-semibold">
        Discover our services
        <span class="text-yellow-500">&rarr;</span>
      </a>
    </div>

    <div class="grid grid-cols-2 border-l border-t border-neutral-300 md:grid-cols-3 lg:grid-cols-5">
      {services.map((service) => (
        <a
          href="/services"
          class="flex min-h-36 flex-col items-center justify-center border-b border-r border-neutral-300 p-6 text-center transition hover:bg-white"
        >
          <svg
            viewBox="0 0 24 24"
            class="mb-4 h-8 w-8"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={svg[service.icon] || svg.target}
          />

          <span class="max-w-[120px] text-sm font-semibold leading-tight">
            {service.title}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>