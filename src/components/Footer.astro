---
const pathname = Astro.url.pathname;
const isContactPage = pathname.startsWith("/contact");
---

<footer class="bg-[#111] text-white">

  <div class="mx-auto max-w-7xl px-8 py-20">

    <div class="flex flex-col gap-12 lg:flex-row lg:items-end lg:justify-between">

      <div>

        <h2 class="max-w-xl text-5xl font-black leading-[0.95] tracking-[-0.04em]">
          Let's create something meaningful together.
        </h2>

      </div>

      {
  !isContactPage && (
    <a
      href="/contact"
      class="inline-flex w-fit items-center bg-[#f2c500] px-10 py-5 font-bold text-black transition hover:translate-y-[-2px]"
    >
      Contact us
      <span class="ml-2">&rarr;</span>
    </a>
  )
}

    </div>

    <div class="mt-16 border-t border-white/10 pt-10">

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-5">

        <div>
          <img
            src="/logo-white.svg"
            alt="L'Union"
            class="w-36"
          />
        </div>

        <div>
  <p class="text-sm text-white/60">Email</p>

  <a
    href="mailto:hello@l-union.be"
    class="mt-2 inline-block transition hover:text-[#f2c500]"
  >
    hello@l-union.be
  </a>
</div>

<div>
  <p class="text-sm text-white/60">Phone</p>

  <a
    href="tel:+32479998493"
    class="mt-2 inline-block transition hover:text-[#f2c500]"
  >
    +32 479 99 84 93
  </a>
</div>

<div>
  <p class="text-sm text-white/60">Follow</p>

  <div class="mt-2 flex flex-col gap-2">

    <a
      href="https://www.linkedin.com/company/l'union/"
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:text-[#f2c500]"
    >
      LinkedIn
    </a>

    <a
      href="https://www.instagram.com/lunionfrombxl/"
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:text-[#f2c500]"
    >
      Instagram
    </a>

    <a
      href="https://vimeo.com/lunion"
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:text-[#f2c500]"
    >
      Vimeo
    </a>

    <a
      href="https://l-union.wetransfer.com"
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:text-[#f2c500]"
    >
      WeTransfer
    </a>

  </div>
</div>

        </div>

      </div>

    </div>

  </div>

</footer>