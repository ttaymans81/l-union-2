---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <section class="mx-auto max-w-7xl px-8 py-24">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
      Contact
    </p>

    <h1 class="mt-6 max-w-4xl text-6xl font-black leading-[0.95] tracking-[-0.05em]">
      Ready to create impact?
    </h1>

    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-neutral-600">
      Let's talk about your next project, campaign or communication challenge.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-8 pb-24">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="bg-[#f1f0ec] p-10">
        <h2 class="text-3xl font-black">Get in touch</h2>

        <div class="mt-8 space-y-6 text-lg">
          <p>
    <span class="text-neutral-500">Email</span><br />

    <a
      href="mailto:hello@l-union.be"
      class="transition hover:text-[#f2c500]"
    >
      hello@l-union.be
    </a>
  </p>

  <p>
    <span class="text-neutral-500">Phone</span><br />

    <a
      href="tel:+32479998493"
      class="transition hover:text-[#f2c500]"
    >
      +32 479 99 84 93
    </a>
  </p>

  <p>
    <span class="text-neutral-500">Location</span><br />
    Brussels, Belgium
  </p>
        </div>
      </div>

      <div class="bg-[#111] p-10 text-white">
        <h2 class="text-3xl font-black">Book a meeting</h2>

        <p class="mt-6 leading-relaxed text-white/70">
          Schedule a conversation with L'UNION to explore how we can help.
        </p>

        <a
          href="https://calendly.com/lunion/introduction-call"
          class="mt-10 inline-block bg-[#f2c500] px-10 py-5 font-bold text-black"
        >
          Book a meeting <span class="ml-2">&rarr;</span>
        </a>
      </div>
    </div>
  </section>
</MainLayout>