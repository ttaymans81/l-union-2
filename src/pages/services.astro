---
import MainLayout from "../layouts/MainLayout.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
---

<MainLayout>

<section class="mx-auto max-w-7xl px-8 py-24">

  <p class="uppercase text-sm tracking-[0.25em] text-neutral-500">
    Services
  </p>

  <h1 class="mt-6 max-w-3xl text-6xl font-black leading-[0.95]">
    Strategic, creative and digital services for organizations that want impact.
  </h1>

  <p class="mt-8 max-w-2xl text-lg leading-relaxed text-neutral-600">
    From strategy to campaigns, digital experiences and production,
    L'Union helps brands and institutions connect with the people who matter.
  </p>

</section>

<ServicesGrid />

</MainLayout>