---
import Button from "./Button.astro";
---

<section class="mx-auto grid max-w-7xl items-center gap-24 px-8 pb-28 pt-14 lg:grid-cols-[0.44fr_0.56fr]">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-neutral-500">
      Strategy, creativity, impact
    </p>

    <h1 class="mt-6 max-w-[12ch] text-5xl font-black leading-[0.94] tracking-[-0.05em] lg:text-7xl">
      We create strategies and experiences that move organizations forward.
    </h1>

    <p class="mt-8 max-w-md text-lg leading-relaxed text-neutral-500">
      We help brands and institutions build meaningful connections.
    </p>

    <div class="mt-12 flex flex-wrap gap-6">
      <Button label="View Case Studies" href="/case-studies" />
      <Button label="Let's Talk" href="/contact" variant="secondary" />
    </div>
  </div>

  <div class="relative min-h-[560px] overflow-hidden bg-[#eceae4]">

  <img
    src="/images/hero.jpg"
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
  />

  <img
    src="/apostrophe.png"
    alt=""
    class="absolute right-16 top-16 w-[90px]"
  />

</div>
</section>