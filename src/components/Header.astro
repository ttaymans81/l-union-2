---
const { currentPath = "/" } = Astro.props;

const links = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Team", href: "/team" },
  { label: "Contact", href: "/contact" },
];

const isActive = (href) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="mx-auto max-w-7xl px-6 py-6 md:px-8 md:py-8">
  <div class="flex items-center justify-between">
    <a href="/">
      <img
        src="/LUNION.png"
        alt="L'Union"
        class="w-[150px] md:w-[180px]"
      />
    </a>

    <nav class="hidden lg:flex gap-10 text-[18px] font-medium">
      {links.map((link) => (
        <a
          href={link.href}
          class={`${isActive(link.href) ? "text-black" : "text-neutral-500"} transition hover:text-black`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <details class="relative block lg:hidden">
      <summary class="flex cursor-pointer list-none items-center">
  <span class="flex flex-col gap-1">
    <span class="block h-[2px] w-7 bg-black"></span>
    <span class="block h-[2px] w-7 bg-black"></span>
    <span class="block h-[2px] w-7 bg-black"></span>
  </span>
</summary>

      <div class="absolute right-0 z-50 mt-5 w-[220px] bg-[#f7f6f2] p-6 shadow-xl">
        <nav class="flex flex-col gap-5 text-lg font-semibold">
          {links.map((link) => (
            <a
              href={link.href}
              class={`${isActive(link.href) ? "text-black" : "text-neutral-500"} transition hover:text-black`}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </details>
  </div>
</header>