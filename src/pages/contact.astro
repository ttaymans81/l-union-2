---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <section class="mx-auto max-w-7xl px-8 py-24">
    <p class="uppercase text-sm tracking-[0.25em] text-neutral-500">
      Contact
    </p>

    <h1 class="mt-6 max-w-4xl text-6xl font-black leading-[0.95]">
      Ready to create impact?
    </h1>

    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-neutral-600">
      Let’s talk about your next project, campaign or communication challenge.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-8 pb-24">
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="bg-[#f1f0ec] p-10">
        <h2 class="text-2xl font-bold">Get in touch</h2>

        <div class="mt-8 space-y-5 text-lg">
          <p>
            <span class="text-neutral-500">Email</span><br />
            info@l-union.be
          </p>

          <p>
            <span class="text-neutral-500">Phone</span><br />
            +32 2 880 66 77
          </p>

          <p>
            <span class="text-neutral-500">Location</span><br />
            Brussels, Belgium
          </p>
        </div>
      </div>

      <div class="bg-[#111] p-10 text-white">
        <h2 class="text-2xl font-bold">Book a meeting</h2>

        <p class="mt-6 text-white/70 leading-relaxed">
          Schedule a conversation with L'Union to explore how we can help.
        </p>

        <a
          href="#"
          class="mt-10 inline-block bg-yellow-400 px-8 py-4 font-bold text-black"
        >
          Book a meeting &rarr;
        </a>
      </div>
    </div>
  </section>
</MainLayout>