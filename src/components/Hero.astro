---
import Button from "./Button.astro";

const { homepage } = Astro.props;

const eyebrow = homepage?.heroEyebrow || "Strategy, creativity, impact";
const title =
  homepage?.heroTitle ||
  "We create strategies and experiences that move organizations forward.";
const subtitle =
  homepage?.heroSubtitle ||
  "We help brands and institutions build meaningful connections.";
const imageUrl = homepage?.heroImageUrl || "/images/hero.jpg";
---

<section class="mx-auto grid max-w-7xl items-center gap-12 px-6 pb-20 pt-10 md:px-8 md:pb-28 md:pt-14 lg:grid-cols-[0.44fr_0.56fr] lg:gap-24">
  <div>
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-neutral-500 md:tracking-[0.25em]">
      {eyebrow}
    </p>

    <h1 class="mt-6 max-w-[11ch] text-[3.35rem] font-black leading-[0.92] tracking-[-0.06em] md:text-6xl lg:text-7xl">
      {title}
    </h1>

    <p class="mt-7 max-w-md text-lg leading-relaxed text-neutral-500 md:mt-8">
      {subtitle}
    </p>

    <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:flex-wrap md:mt-12 md:gap-6">
      <Button label="View Case Studies" href="/case-studies" />
      <Button label="Let's Talk" href="/contact" variant="secondary" />
    </div>
  </div>

  <div class="relative min-h-[420px] overflow-hidden bg-[#eceae4] md:min-h-[560px]">
    <img
      src={imageUrl}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
    />

    <img
      src="/apostrophe.png"
      alt=""
      class="absolute right-8 top-8 w-[70px] md:right-16 md:top-16 md:w-[90px]"
    />
  </div>
</section>