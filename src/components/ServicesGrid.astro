---
import { services } from "../data/services";
---

<section class="bg-[#f1f0ec]">

<div class="max-w-7xl mx-auto px-8 py-20">

<p class="uppercase text-sm tracking-[0.25em] text-neutral-500">
Services
</p>

<h2 class="text-4xl font-bold mt-5">
Services that create impact
</h2>

<div class="grid md:grid-cols-3 gap-6 mt-12">

{services.map((service)=>

<div class="border p-8 hover:bg-white transition">

<div class="w-8 h-8 border rounded-full mb-5"></div>

<p class="font-semibold">
{service}
</p>

</div>

)}

</div>

</div>

</section>